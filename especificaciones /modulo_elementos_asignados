import { z } from 'zod';

export const ItemControlSchema = z.object({
  elementoId: z.string().uuid(),
  estadoOperativo: z.enum(['ok', 'falla', 'faltante']),
  observacion: z.string().optional(),
}).refine((data) => {
  if ((data.estadoOperativo === 'falla' || data.estadoOperativo === 'faltante') && (!data.observacion || data.observacion.trim().length < 10)) {
    return false;
  }
  return true;
}, {
  message: "Debes ingresar una justificación detallada de al menos 10 caracteres para reportar fallas o faltantes.",
  path: ["observacion"]
});

export const RelevoInventarioSchema = z.object({
  turnoNuevoId: z.string().uuid(),
  turnoAnteriorId: z.string().uuid(),
  tecnicoEntranteId: z.string().uuid(),
  tecnicoSalienteId: z.string().uuid(),
  clienteId: z.string().uuid(),
  controles: z.array(ItemControlSchema).min(1, { message: "Debe auditar al menos un elemento." })
});

export const ReporteFallaIntraturnoSchema = z.object({
  turnoId: z.string().uuid(),
  elementoId: z.string().uuid(),
  tecnicoId: z.string().uuid(),
  descripcionFalla: z.string().min(10, { message: "Explicá el desperfecto con al menos 10 caracteres." })
});


4. Arquitectura de Endpoints y Lógica de Negocio Atómica
4.1. Relevo de Guardia con Imputación Automatizada
Ruta del archivo: /app/api/inventario/relevo/route.ts

import { createRouteHandlerClient } from '@supabase/ssr';
import { cookies } from 'next/headers';
import { NextResponse } from 'next/server';
import { RelevoInventarioSchema } from '@/schemas/inventario';

export async function POST(request: Request) {
  try {
    const body = await request.json();
    const validated = RelevoInventarioSchema.parse(body);
    const supabase = createRouteHandlerClient({ cookies });

    // Iterar de forma segura sobre los elementos auditados en el relevo
    for (const control of validated.controles) {
      // 1. Insertar el registro de auditoría estricto para el nuevo turno
      const { error: insError } = await supabase
        .from('control_inventario_turno')
        .insert({
          turno_id: validated.turnoNuevoId,
          elemento_id: control.elementoId,
          estado_operativo: control.estadoOperativo,
          observacion: control.observacion
        });

      if (insError) return NextResponse.json({ error: insError.message }, { status: 400 });

      // 2. Escenario de Imputación por Omisión (Técnico Saliente no avisó de la rotura/faltante)
      if (control.estadoOperativo === 'falla' || control.estadoOperativo === 'faltante') {
        
        // Obtener metadatos del elemento para armar el ticket formal
        const { data: item } = await supabase
          .from('elementos_puesto')
          .select('nombre, codigo_patrimonial')
          .eq('id', control.elementoId)
          .single();

        const esFaltante = control.estadoOperativo === 'faltante';
        const tituloTicket = `${esFaltante ? '🚨 [FALTANTE CRÍTICO]' : '⚠️ [FALLA DE INVENTARIO]'} - ${item?.nombre}`;
        
        // Inyectar incidencia automatizada cruzada deslindando al Técnico Entrante
        await supabase
          .from('incidencias')
          .insert({
            cliente_id: validated.clienteId,
            turno_creacion_id: validated.turnoNuevoId,
            titulo: tituloTicket,
            descripcion: `Incidencia de control patrimonial automatizada generada durante el relevo de guardia.\\n\\nDetalle del hallazgo: "${control.observacion}"\\n\\nCódigo de activo afectado: ${item?.codigo_patrimonial}`,
            severidad: esFaltante ? 'alta' : 'media',
            estado: 'abierto',
            elemento_afectado_id: control.elementoId,
            tecnico_detector_id: validated.tecnicoEntranteId,
            tecnico_imputado_id: validated.tecnicoSalienteId, -- Imputación directa al turno anterior
            turno_imputado_id: validated.turnoAnteriorId
          });

        // Estampar el rastro legal inmutable dentro del libro de novedades del turno entrante
        await supabase
          .from('libro_novedad')
          .insert({
            turno_id: validated.turnoNuevoId,
            tipo: esFaltante ? 'alerta' : 'novedad',
            hora: new Date().toLocaleTimeString('es-AR', { hour: '2-digit', minute: '2-digit' }),
            descripcion: `${tituloTicket}. Código Patrimonial: ${item?.codigo_patrimonial}. Hallazgo: ${control.observacion}. Responsabilidad deslindada ante supervisión.`
          });
      }
    }

    return NextResponse.json({ success: true }, { status: 200 });
  } catch (err: any) {
    return NextResponse.json({ error: err.message || 'Internal Error' }, { status: 500 });
  }
}

4.2. Reporte de Desperfecto Intraturno (Empleado Honesto)
Ruta del archivo: /app/api/inventario/reportar-falla/route.ts


import { createRouteHandlerClient } from '@supabase/ssr';
import { cookies } from 'next/headers';
import { NextResponse } from 'next/server';
import { ReporteFallaIntraturnoSchema } from '@/schemas/inventario';

export async function POST(request: Request) {
  try {
    const body = await request.json();
    const validated = ReporteFallaIntraturnoSchema.parse(body);
    const supabase = createRouteHandlerClient({ cookies });

    const { data: item } = await supabase
      .from('elementos_puesto')
      .select('nombre, codigo_patrimonial, cliente_id')
      .eq('id', validated.elementoId)
      .single();

    // 1. Crear incidencia de forma voluntaria asumiendo la responsabilidad del hecho durante su guardia
    await supabase.from('incidencias').insert({
      cliente_id: item?.cliente_id,
      turno_creacion_id: validated.turnoId,
      titulo: `⚠️ [DESPERFECTO EN GUARDIA] - ${item?.nombre}`,
      descripcion: `El técnico reportó de manera voluntaria un daño ocurrido durante el transcurso operativo de su turno.\\n\\nDetalle del daño: "${validated.descripcionFalla}"\\n\\nActivo ID: ${item?.codigo_patrimonial}`,
      severidad: 'media',
      estado: 'abierto',
      elemento_afectado_id: validated.elementoId,
      tecnico_detector_id: validated.tecnicoId,
      tecnico_imputado_id: validated.tecnicoId, -- El mismo usuario asume la trazabilidad del evento
      turno_imputado_id: validated.turnoId
    });

    // 2. Dejar asentado de forma obligatoria en el feed lineal (Timeline) del libro actual
    await supabase.from('libro_novedad').insert({
      turno_id: validated.turnoId,
      tipo: 'novedad',
      hora: new Date().toLocaleTimeString('es-AR', { hour: '2-digit', minute: '2-digit' }),
      descripcion: `⚠️ [DAÑO DE MATERIAL] - Se reporta desperfecto en equipo: ${item?.nombre} (${item?.codigo_patrimonial}). Detalle: ${validated.descripcionFalla}`
    });

    return NextResponse.json({ success: true }, { status: 200 });
  } catch (err: any) {
    return NextResponse.json({ error: 'Internal Server Error' }, { status: 500 });
  }
}

